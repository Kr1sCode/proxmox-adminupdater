{
  "settings": {
    "pve_host": "CHANGE_ME",
    "pve_port": 8006,
    "verify_tls": false,
    "paused": false,
    "snapshot_prefix": "preupd",
    "rollback_on_fail": false,
    "default_keep": 3,
    "default_max_age_days": 0,
    "ram_boost": false,
    "ram_boost_mb": 4096
  },
  "auth": {
    "allowlist": ["root@pam"]
  },
  "guests": {
    "105": {
      "enabled": true,
      "mode": "calendar",
      "times": ["03:30"],
      "weekdays": [6],
      "security_patch": true,
      "app_update": "example-app",
      "pre_snapshot": true,
      "keep": null,
      "max_age_days": null,
      "health_check": { "type": "systemd", "arg": "docker" },
      "snapshot": {
        "enabled": true,
        "mode": "calendar",
        "times": ["02:00"],
        "weekdays": [],
        "prefix": "auto",
        "keep": 7,
        "max_age_days": 0,
        "dryrun": false
      }
    }
  }
}
