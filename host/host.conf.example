[main]
# URL of the adminupdater LXC (the container running the web UI). Plain :80 on
# the LAN is fine; the executor authenticates with the bearer token below.
updater_url    = http://CHANGE_ME_CT_IP

# Shared bearer secret. MUST match /etc/adminupdater/exec_token inside the LXC.
token          = CHANGE_ME

# HOST-authoritative whitelist -- the real safety boundary. A ctid absent here
# is refused even if the LXC lists it. Opt-in only; start empty.
# Changes take effect on the NEXT timer tick (no restart needed).
#   allowed_ctids = 101,102,105   -> only these
#   allowed_ctids = *             -> "trust the panel": the LXC whitelist alone
#                                    decides. Convenient for a homelab, but drops
#                                    the second gate -> a compromised panel LXC
#                                    could then drive updates on ANY guest.
allowed_ctids  =

# Host-trusted app update recipes (the LXC supplies only the recipe name).
recipes_dir    = /etc/proxmox-adminupdater/recipes

exec_timeout   = 1800
tls_insecure   = false

# Ceiling (MB) for the panel's temporary "RAM boost during updates" feature. When
# enabled in the panel, a guest's RAM is raised for the memory-heavy app-update build
# (npm install / from-source compiles that OOM at tight limits -> rc=137) and restored
# afterwards. The panel picks the target; the HOST clamps it here so a compromised LXC
# can never set an absurd limit on a whitelisted guest. Set to a value your host can
# actually spare across concurrent updates.
ram_boost_max_mb = 8192

# E-mail report (HTML) after each run.
# notify_via: pve      -> reuse Proxmox's configured SMTP notification target
#                        (reads /etc/pve/notifications.cfg + the password in
#                        /etc/pve/priv/notifications.cfg). No creds duplicated.
#             sendmail -> host postfix/sendmail (needs notify_email set below).
# notify_on:  always | errors | never
notify_via     = pve
notify_on      = errors
# notify_email = you@example.com    (only for notify_via = sendmail)
# notify_from  = adminupdater@pve   (default: adminupdater@<hostname>)

# Update the PVE HOST itself when the panel schedules it (second gate: OFF by
# default, so a compromised panel LXC cannot upgrade the hypervisor on its own).
# The command is host-side and trusted — the panel only decides the timing.
host_update      = off
host_update_cmd  = apt update && apt --yes --no-new-pkgs upgrade
host_update_log  = /var/log/proxmox-apt-upgrade.log
